---
interface Props {
  title?: string;
}
const { title = "Euddy Cabrera — Full Stack Developer" } = Astro.props;

import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/code.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta
      name="description"
      content="Full Stack Developer con experiencia en el desarrollo de aplicaciones web modernas, rápidas y fáciles de usar. Diseño interfaces atractivas combinadas con sistemas potentes y seguros para hacer crecer tu negocio o proyecto."
    />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Euddy Cabrera | Full Stack Developer" />
    <meta
      property="og:description"
      content="Especialista en crear aplicaciones web modernas, rápidas y fáciles de usar. Diseño interfaces atractivas combinadas con sistemas potentes y seguros para hacer crecer tu negocio o proyecto."
    />
    <meta property="og:image" content="/captura1.jpg" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta
      property="twitter:title"
      content="Euddy Cabrera | Full Stack Developer"
    />
    <meta
      property="twitter:description"
      content="Especialista en crear aplicaciones web modernas, rápidas y fáciles de usar. Diseño interfaces atractivas combinadas con sistemas potentes y seguros para hacer crecer tu negocio o proyecto."
    />
    <meta property="twitter:image" content="/captura1.jpg" />

    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@300;400;500;600&family=Inter:wght@500;700;800;900&family=Space+Grotesk:wght@600;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      const initTheme = () => {
        const theme = (() => {
          if (
            typeof localStorage !== "undefined" &&
            localStorage.getItem("theme")
          ) {
            return localStorage.getItem("theme");
          }
          return "dark";
        })();
        if (theme === "light") {
          document.documentElement.classList.add("light");
        } else {
          document.documentElement.classList.remove("light");
        }
      };

      initTheme();
      document.addEventListener("astro:after-swap", () => {
        initTheme();
        document.documentElement.classList.add("no-hero-animations");
      });
    </script>
    <ClientRouter />
  </head>
  <body>
    <slot />

    <script>
      import { play } from "cuelume";

      function initInteractionSounds() {
        // Prevent multiple initializations
        if (window.__interactionSoundsInitialized) return;
        window.__interactionSoundsInitialized = true;

        document.addEventListener("mouseover", (e) => {
          const target = e.target.closest(
            "a, button, .project-carousel-card, .contact-link",
          );
          if (target && !target.dataset.hovered) {
            target.dataset.hovered = "true";

            if (
              target.classList.contains("project-carousel-card") ||
              target.closest(".project-carousel-card")
            ) {
              play("bloom");
            } else if (target.classList.contains("copy-email-btn")) {
              play("whisper");
            } else if (target.classList.contains("contact-link")) {
              play("droplet");
            } else {
              play("tick");
            }

            target.addEventListener(
              "mouseleave",
              () => {
                target.dataset.hovered = "";
              },
              { once: true },
            );
          }
        });

        document.addEventListener("mousedown", (e) => {
          const target = e.target.closest(
            "a, button, .project-carousel-card, .contact-link",
          );
          if (target && target.id !== "theme-toggle") {
            if (target.classList.contains("copy-email-btn")) {
              play("success");
            } else if (
              target.classList.contains("project-carousel-card") ||
              target.closest(".project-carousel-card")
            ) {
              play("chime");
            } else if (target.classList.contains("contact-link")) {
              play("sparkle");
            } else {
              play("press");
            }
          }
        });
      }

      initInteractionSounds();
      document.addEventListener("astro:after-swap", () => {
        window.__interactionSoundsInitialized = false;
        initInteractionSounds();
      });
    </script>
  </body>
</html>
