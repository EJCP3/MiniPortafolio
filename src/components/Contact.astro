---
interface Profile {
    network: string;
    username: string;
    url: string;
}

interface Props {
    name: string;
    email: string;
    profiles: Profile[];
}

const { name, email, profiles } = Astro.props;
const reversedEmail = email.split("").reverse().join("");

const nameParts = name.trim().split(" ");
const initials = nameParts.map((p) => p[0]?.toLowerCase()).join("");
---

<section
    id="contact"
    class="pt-[100px] pb-[60px] border-t border-bg2 relative overflow-hidden contact-glow"
>
    <div class="max-w-[1080px] mx-auto px-6">
        <h2
            class="font-mono font-extrabold text-cream tracking-tight leading-[1.6] text-center mb-3.5 reveal"
            style="font-size: clamp(28px, 4vw, 10px);"
        >
            Si algo de esto te llama la atención, te hace pensar, <em
                class="italic text-accent-orange">¡hablemos!.</em
            >
        </h2>

        <address class="not-italic">
            <ul
                class="grid grid-cols-1 gap-4 max-w-[780px] mx-auto mb-16 md:grid-cols-2 p-0 m-0 list-none"
            >
                <li class="w-full">
                    <button
                        data-conf={reversedEmail}
                        class="contact-link copy-email-btn flex items-center gap-3.5 bg-bg1 border border-bg3 rounded-[14px] py-[18px] px-5 no-underline text-fg transition-all duration-250 relative overflow-hidden hover:-translate-y-[3px] hover:border-accent-orange hover:shadow-[0_12px_32px_rgba(0,0,0,0.3)] reveal w-full text-left cursor-pointer"
                    >
                        <div
                            class="w-[38px] h-[38px] rounded-[10px] flex items-center justify-center text-lg shrink-0 bg-accent-orange/[0.12]"
                        >
                            <svg class="w-5 h-5 shrink-0" viewBox="0 0 50 50">
                                <use href={`/sprite.svg#email`}></use>
                            </svg>
                        </div>
                        <div>
                            <p
                                class="text-[11px] tracking-wider uppercase text-fg-sub mb-0.5 email-label transition-colors duration-200"
                            >
                                Email
                            </p>
                            <p 
                                class="text-[13px] font-medium text-fg"
                                style="unicode-bidi: bidi-override; direction: rtl; text-align: left;"
                            >
                                {reversedEmail}
                            </p>
                        </div>
                    </button>
                </li>

                {
                    profiles.map((profile) => {
                        const networkLower = profile.network.toLowerCase();
                        const bgClass =
                            networkLower === "github"
                                ? "bg-cream/[0.08]"
                                : networkLower === "linkedin"
                                  ? "bg-accent-teal/[0.12]"
                                  : networkLower === "whatsapp"
                                    ? "bg-accent-green/[0.12]"
                                    : "bg-accent-orange/[0.12]";

                        return (
                            <li class="w-full">
                                <a
                                    href={profile.url}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="contact-link flex items-center gap-3.5 bg-bg1 border border-bg3 rounded-[14px] py-[18px] px-5 no-underline text-fg transition-all duration-250 relative overflow-hidden hover:-translate-y-[3px] hover:border-accent-orange hover:shadow-[0_12px_32px_rgba(0,0,0,0.3)] reveal"
                                >
                                    <div
                                        class={`w-[38px] h-[38px] rounded-[10px] flex items-center justify-center text-lg shrink-0 ${bgClass}`}
                                    >
                                        {networkLower === "github" && (
                                            <svg
                                                width="18"
                                                height="18"
                                                viewBox="0 0 24 24"
                                                fill="var(--color-fg)"
                                                xmlns="http://www.w3.org/2000/svg"
                                            >
                                                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
                                            </svg>
                                        )}
                                        {networkLower === "linkedin" && (
                                            <svg
                                                width="18"
                                                height="18"
                                                viewBox="0 0 24 24"
                                                fill="#83a598"
                                                xmlns="http://www.w3.org/2000/svg"
                                            >
                                                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                                            </svg>
                                        )}
                                    </div>
                                    <div>
                                        <p class="text-[11px] tracking-wider uppercase text-fg-sub mb-0.5">
                                            {profile.network}
                                        </p>
                                        <p class="text-[13px] font-medium text-fg">
                                            {profile.username}
                                        </p>
                                    </div>
                                </a>
                            </li>
                        );
                    })
                }
            </ul>
        </address>

        <footer
            class="text-center border-t border-bg2 pt-8 flex flex-col items-center gap-2"
        >
            <p
                class="font-italic text-[16px] font-extrabold text-cream tracking-tight"
            >
                Creando con mucho amor <span
                    class="text-accent-orange text-sm font-light italic"
                    >y con musica de fondo.</span
                >
                <span class="text-accent-orange"></span>
            </p>
            <p class="text-[11px] text-fg-sub tracking-wider">
                © {new Date().getFullYear()}
                {name.trim()}.
            </p>
        </footer>
    </div>
</section>

<script>
    function initEmail() {
        const copyBtns = document.querySelectorAll(".copy-email-btn");
        copyBtns.forEach((btn) => {
            btn.addEventListener("click", async () => {
                const conf = btn.getAttribute("data-conf");
                if (conf) {
                    // Revertimos la cadena para que al copiar sea el email correcto
                    const originalEmail = conf.split("").reverse().join("");
                    try {
                        await navigator.clipboard.writeText(originalEmail);
                        const label = btn.querySelector(".email-label");
                        if (label) {
                            label.textContent = "¡Copiado!";
                            label.classList.add("text-accent-orange");
                            setTimeout(() => {
                                label.textContent = "Email";
                                label.classList.remove("text-accent-orange");
                            }, 2000);
                        }
                    } catch (err) {
                        console.error("Error al copiar: ", err);
                    }
                }
            });
        });
    }

    // Ejecutar al cargar
    initEmail();

    // Re-ejecutar si se usa ViewTransitions de Astro
    document.addEventListener("astro:after-swap", initEmail);
</script>
