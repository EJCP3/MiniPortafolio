---
interface ExperienceItem {
    company: string;
    position: string;
    startDate: string;
    endDate: string;
    location: string;
    description: string;
    technologies: string[];
}

interface Props {
    experience: ExperienceItem[];
}

const { experience = [] } = Astro.props;
---

<section id="experience" class="py-[120px] relative">
    <div class="max-w-[1080px] mx-auto px-6">
        <header class="text-center mb-[60px] reveal">
            <p class="text-[8px] tracking-[0.2em] uppercase text-accent-yellow mb-3">
                // experiencia profesional
            </p>
            <h2 class="font-extrabold text-cream tracking-[-1.5px] leading-none text-xl">
                 Trayectoria y Desarrollo
            </h2>
            <p class="mt-3.5 text-accent-teal-d text-xs max-w-[480px] mx-auto">
               Un recorrido por las empresas y proyectos donde he aportado valor y soluciones reales.
            </p>
        </header>

        <div class="grid grid-cols-1 gap-6 max-w-[800px] mx-auto">
            {
                experience.map((exp, i) => (
                    <article class="p-8 rounded-[var(--radius-card-lg)] bg-project-bg-3 border-[length:var(--card-border-width)] border-[color:var(--border-color-card)] hover:border-[color:var(--border-color-card-hover)] shadow-[var(--shadow-hard-card)] hover:shadow-[var(--shadow-hard-card)] transition-all reveal">
                        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-4">
                            <div>
                                <h3 class="text-lg font-bold text-cream mb-1">{exp.position}</h3>
                                <p class="text-sm font-medium text-accent-yellow">{exp.company}</p>
                            </div>
                            <div class="text-left md:text-right">
                                <span class="text-xs text-fg-sub bg-bg2 px-3 py-1 rounded-[var(--radius-card)] border-[length:var(--pill-border-width)] border-border-base shadow-[var(--shadow-hard-pill)]">
                                    {exp.startDate} — {exp.endDate} | {exp.location}
                                </span>
                            </div>
                        </div>
                        
                        <p class="text-sm text-fg-sub mb-6 leading-relaxed">
                            {exp.description}
                        </p>
                        
                        <div class="flex flex-wrap gap-2">
                            {exp.technologies.map(tech => (
                                <span class="px-2 py-1 text-[10px] uppercase tracking-wider font-semibold rounded-[var(--radius-card)] bg-tag-yellow text-cream border-[length:var(--pill-border-width)] border-[color:var(--border-color-card)] shadow-[var(--shadow-hard-pill)]">
                                    {tech}
                                </span>
                            ))}
                        </div>
                    </article>
                ))
            }
        </div>
    </div>
</section>
