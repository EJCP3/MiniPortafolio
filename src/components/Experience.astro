---
interface ExperienceItem {
    company: string;
    position: string;
    startDate: string;
    endDate: string;
    location: string;
    description: string;
    technologies: string[];
}

interface Props {
    experience: ExperienceItem[];
    projectCount?: number;
    skillCount?: number;
}

const { experience = [], projectCount = 6, skillCount = 15 } = Astro.props;
---

<section id="experience" class="py-[100px] relative">
    <div class="max-w-[1080px] mx-auto px-6">
        <!-- Stats row (eleveight style) -->
        <div class="grid grid-cols-3 gap-8 mb-20 max-w-[700px] mx-auto text-center reveal">
            <div>
                <p class="font-sans font-extrabold text-cream tracking-[-2px] leading-none mb-2" style="font-size: clamp(40px, 6vw, 64px);">
                    {projectCount}<span class="text-accent-orange">+</span>
                </p>
                <p class="text-[11px] text-fg-sub tracking-[0.2em] uppercase font-mono">
                    Proyectos finalizados
                </p>
            </div>
            <div>
                <p class="font-sans font-extrabold text-cream tracking-[-2px] leading-none mb-2" style="font-size: clamp(40px, 6vw, 64px);">
                    1<span class="text-accent-orange">+</span>
                </p>
                <p class="text-[11px] text-fg-sub tracking-[0.2em] uppercase font-mono">
                    Año experiencia
                </p>
            </div>
            <div>
                <p class="font-sans font-extrabold text-cream tracking-[-2px] leading-none mb-2" style="font-size: clamp(40px, 6vw, 64px);">
                    {skillCount}<span class="text-accent-orange">+</span>
                </p>
                <p class="text-[11px] text-fg-sub tracking-[0.2em] uppercase font-mono">
                    Tecnologías
                </p>
            </div>
        </div>

        <!-- Section header -->
        <header class="text-center mb-[60px] reveal">
            <p class="text-[10px] tracking-[0.25em] uppercase text-accent-yellow mb-3 font-mono">
                // experiencia profesional
            </p>
            <h2 class="font-sans font-extrabold text-cream tracking-[-1.5px] leading-tight text-xl md:text-2xl">
                Trayectoria y Desarrollo
            </h2>
            <p class="mt-3.5 text-fg-sub text-xs max-w-[480px] mx-auto">
                Un recorrido por las empresas y proyectos donde he aportado valor y soluciones reales.
            </p>
        </header>

        <!-- Experience cards -->
        <div class="grid grid-cols-1 gap-6 max-w-[800px] mx-auto">
            {
                experience.map((exp, i) => (
                    <article class="p-8 rounded-[var(--radius-card-lg)] bg-bg1 border-[length:var(--card-border-width)] border-[color:var(--border-color-card)] hover:border-[color:var(--border-color-card-hover)] shadow-[var(--shadow-hard-card)] transition-all reveal">
                        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-4">
                            <div>
                                <h3 class="text-lg font-bold text-cream mb-1 font-sans">{exp.position}</h3>
                                <p class="text-sm font-medium text-accent-yellow">{exp.company}</p>
                            </div>
                            <div class="text-left md:text-right">
                                <span class="text-xs text-fg-sub bg-bg2 px-3 py-1 rounded-[var(--radius-card)] border-[length:var(--pill-border-width)] border-border-base shadow-[var(--shadow-hard-pill)] font-mono">
                                    {exp.startDate} — {exp.endDate} | {exp.location}
                                </span>
                            </div>
                        </div>
                        
                        <p class="text-sm text-fg-sub mb-6 leading-relaxed">
                            {exp.description}
                        </p>
                        
                        <div class="flex flex-wrap gap-2">
                            {exp.technologies.map(tech => (
                                <span class="px-2.5 py-1 text-[10px] uppercase tracking-wider font-semibold rounded-[var(--radius-card)] tag-yellow border-[length:var(--pill-border-width)] border-[color:var(--border-color-card)] shadow-[var(--shadow-hard-pill)] font-mono">
                                    {tech}
                                </span>
                            ))}
                        </div>
                    </article>
                ))
            }
        </div>
    </div>
</section>
