---
interface Props {
    mini: {
        name: string;
        description: string;
        technologies: string[];
        link: string;
        icon?: string;
    };
    index: number;
    sizeClass: string;
    borderClass: string;
    accentClass: string;
}

const { mini, index, sizeClass, borderClass, accentClass } = Astro.props;
---

<a
    href={mini.link}
    target="_blank"
    rel="noopener noreferrer"
    class={`group bg-bg1 border rounded-card-lg p-5 no-underline transition-all duration-300 relative overflow-hidden hover:-translate-y-1 hover:shadow-[0_16px_40px_rgba(0,0,0,0.3)] ${sizeClass} ${borderClass}`}
>
    <!-- Subtle gradient glow on hover -->
    <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none" style={`background: radial-gradient(circle at 30% 50%, rgba(254,128,25,0.04), transparent 70%);`}></div>

    <div class="relative z-2 flex flex-col h-full">
        <!-- Header: icon + name -->
        <div class="flex items-center gap-3 mb-3">
            {mini.icon && (
                <div class="w-9 h-9 rounded-[10px] bg-bg2 border border-bg4 flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5" viewBox="0 0 50 50">
                        <use href={`/sprite.svg#${mini.icon}`} />
                    </svg>
                </div>
            )}
            <h4 class={`font-sans font-bold text-sm tracking-tight ${accentClass} group-hover:text-cream transition-colors`}>
                {mini.name}
            </h4>
            <svg class="w-3.5 h-3.5 text-fg-sub ml-auto opacity-0 group-hover:opacity-100 transition-all duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="7" y1="17" x2="17" y2="7" /><polyline points="7 7 17 7 17 17" />
            </svg>
        </div>

        <!-- Description -->
        <p class="text-xs text-fg-dim leading-relaxed mb-auto">
            {mini.description}
        </p>

        <!-- Tech tags -->
        <ul class="flex flex-wrap gap-1.5 mt-3 p-0 m-0 list-none">
            {mini.technologies.map((tech) => (
                <li class="text-[9px] tracking-wider font-medium px-2 py-0.5 rounded-full bg-bg2 border border-bg4 text-fg-sub uppercase">
                    {tech}
                </li>
            ))}
        </ul>
    </div>
</a>
