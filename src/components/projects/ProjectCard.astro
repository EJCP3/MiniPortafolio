---
interface Props {
    project: {
        name: string;
        img: string;
        imgs: string[];
        description: string;
        technologies: string[];
        github?: string;
        demo?: string;
    };
    index: number;
    accentColor: string;
    bgColor: string;
    tagColors: string[];
}

const { project, index, accentColor, bgColor, tagColors } = Astro.props;
---

<article
    class="project-card bg-bg1 border border-bg3 rounded-card-lg overflow-hidden transition-all duration-300 relative hover:-translate-y-1.5 hover:border-accent-orange/25 hover:shadow-[0_24px_60px_rgba(0,0,0,0.4),0_0_0_1px_rgba(254,128,25,0.1)] reveal flex flex-col"
    style="transition-timing-function: cubic-bezier(0.34, 1.56, 0.64, 1);"
>
    <div class={`h-[3px] w-full ${accentColor}`} />
    
    <!-- Image carousel -->
    <div
        class={`project-carousel w-full aspect-video relative overflow-hidden ${bgColor}`}
        data-interval="3500"
    >
        {project.imgs && project.imgs.length > 1 ? (
            <>
                {project.imgs.map((imgSrc, imgIdx) => (
                    <img
                        src={imgSrc}
                        alt={`${project.name} - ${imgIdx + 1}`}
                        class={`carousel-slide absolute inset-0 w-full h-full object-cover transition-opacity duration-700 ease-in-out ${imgIdx === 0 ? 'opacity-100' : 'opacity-0'}`}
                        loading="lazy"
                    />
                ))}
                <!-- Dot indicators -->
                <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-1.5 z-10">
                    {project.imgs.map((_: string, dotIdx: number) => (
                        <button
                            class={`carousel-dot w-1.5 h-1.5 rounded-full transition-all duration-300 border-none cursor-pointer ${dotIdx === 0 ? 'bg-accent-orange w-4' : 'bg-fg-sub/40'}`}
                            data-index={dotIdx}
                            aria-label={`Imagen ${dotIdx + 1}`}
                        />
                    ))}
                </div>
            </>
        ) : (
            <img
                src={project.img}
                alt={project.name}
                class="w-full h-full object-cover block"
                loading="lazy"
            />
        )}
    </div>

    <div class="p-6 relative z-2">
        <p class="text-[11px] text-fg-sub tracking-[0.15em] mb-2">
            {String(index + 1).padStart(2, "0")} —{" "}
            {project.name}
        </p>
        <h3 class="font-sans text-xl font-bold text-cream mb-2.5 tracking-tight">
            {project.name}
        </h3>
        <p class="text-[13px] text-fg-dim leading-[1.75] mb-[18px]">
            {project.description}
        </p>
        <ul class="flex flex-wrap gap-1.5 mb-[22px] p-0 m-0 list-none">
            {project.technologies.map((tech, j) => (
                <li
                    class={`text-[10px] tracking-wider font-medium px-2.5 py-1 rounded-full border border-bg4 text-fg-sub uppercase ${tagColors[j % 4]}`}
                >
                    {tech}
                </li>
            ))}
        </ul>
        <div class="flex gap-2.5">
            {project.demo && (
                <a
                    href={project.demo}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex-1 inline-flex items-center justify-center gap-[7px] bg-accent-orange text-bg0 font-mono font-semibold text-xs py-[11px] px-4 rounded-card no-underline transition-all duration-200 hover:bg-cream hover:-translate-y-px"
                >
                    <svg
                        width="12"
                        height="12"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                        <polyline points="15 3 21 3 21 9" />
                        <line
                            x1="10"
                            y1="14"
                            x2="21"
                            y2="3"
                        />
                    </svg>
                    Live Demo
                </a>
            )}
            {project.github && (
                <a
                    href={project.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex-1 inline-flex items-center justify-center gap-[7px] bg-transparent text-fg-dim font-mono text-xs py-[11px] px-4 rounded-card border border-bg4 no-underline transition-all duration-200 hover:text-cream hover:border-bg3 hover:bg-bg2"
                >
                    <svg
                        width="13"
                        height="13"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
                    </svg>
                    GitHub
                </a>
            )}
        </div>
    </div>
</article>
