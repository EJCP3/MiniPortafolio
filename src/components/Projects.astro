---
import ProjectCard from "./projects/ProjectCard.astro";
import MiniProjectCard from "./projects/MiniProjectCard.astro";

interface Project {
    name: string;
    img: string;
    imgs: string[];
    description: string;
    technologies: string[];
    github?: string;
    demo?: string;
}

interface MiniProject {
    name: string;
    description: string;
    technologies: string[];
    link: string;
    icon?: string;
}

interface Props {
    projects: Project[];
    miniProjects?: MiniProject[];
}

const { projects, miniProjects = [] } = Astro.props;

const accentColors = [
    "accent-line-orange",
    "accent-line-teal",
    "accent-line-yellow",
    "accent-line-green",
];
const bgColors = [
    "project-bg-1",
    "project-bg-2",
    "project-bg-3",
    "project-bg-4",
];
const tagColors = ["tag-orange", "tag-teal", "tag-yellow", "tag-green"];

const bentoSizes = [
    "md:col-span-2 md:row-span-1",
    "md:col-span-1 md:row-span-1",
    "md:col-span-1 md:row-span-1",
    "md:col-span-1 md:row-span-1",
    "md:col-span-1 md:row-span-1",
    "md:col-span-2 md:row-span-1",
];

const bentoBorders = [
    "border-accent-orange/20 hover:border-accent-orange/50",
    "border-accent-teal/20 hover:border-accent-teal/50",
    "border-accent-yellow/20 hover:border-accent-yellow/50",
    "border-accent-green/20 hover:border-accent-green/50",
    "border-accent-orange/20 hover:border-accent-orange/50",
    "border-accent-teal/20 hover:border-accent-teal/50",
];

const bentoAccent = [
    "text-accent-orange",
    "text-accent-teal",
    "text-accent-yellow",
    "text-accent-green",
    "text-accent-orange",
    "text-accent-teal",
];
---

<section id="projects" class="py-[120px] relative">
    <div class="max-w-[1080px] mx-auto px-6">
        <header class="text-center mb-[60px] reveal">
            <p class="text-[8px] tracking-[0.2em] uppercase text-accent-orange mb-3">
                // proyectos destacados
            </p>
            <h2 class="font-extrabold text-cream tracking-[-1.5px] leading-none text-xl">
                 Desde interfaces hasta APIs — sistemas completos creados para escalar
            </h2>
            <p class="mt-3.5 text-accent-teal-d text-xs max-w-[480px] mx-auto">
               Creandos soluciones que traducen la innovación en impacto real.
            </p>
        </header>

        <div class="grid grid-cols-[repeat(auto-fill,minmax(480px,1fr))] gap-6 max-sm:grid-cols-1 max-md:grid-cols-1">
            {
                projects.map((project, i) => (
                    <ProjectCard 
                        project={project} 
                        index={i}
                        accentColor={accentColors[i % 4]}
                        bgColor={bgColors[i % 4]}
                        tagColors={tagColors}
                    />
                ))
            }
        </div>

        {miniProjects.length > 0 && (
            <aside aria-label="Más proyectos" class="mt-20 reveal">
                <header class="flex items-center gap-4 mb-8">
                    <div class="h-px flex-1 bg-gradient-to-r from-transparent via-bg3 to-transparent"></div>
                    <h3 class="text-[11px] tracking-[0.2em] uppercase text-fg-sub whitespace-nowrap m-0">// more work</h3>
                    <div class="h-px flex-1 bg-gradient-to-r from-transparent via-bg3 to-transparent"></div>
                </header>

                <div class="grid grid-cols-1 md:grid-cols-[repeat(3,minmax(200px,1fr))] gap-3 auto-rows-fr">
                    {miniProjects.map((mini, i) => (
                        <MiniProjectCard 
                            mini={mini}
                            index={i}
                            sizeClass={bentoSizes[i % 6]}
                            borderClass={bentoBorders[i % 6]}
                            accentClass={bentoAccent[i % 6]}
                        />
                    ))}
                </div>
            </aside>
        )}
    </div>
</section>

<script>
  function initCarousels() {
    const carousels = document.querySelectorAll('.project-carousel');

    carousels.forEach((carousel) => {
      const slides = carousel.querySelectorAll('.carousel-slide');
      const dots = carousel.querySelectorAll('.carousel-dot');
      if (slides.length <= 1) return;

      const interval = parseInt(carousel.getAttribute('data-interval') || '5000');
      let current = 0;
      let paused = false;
      let timer: ReturnType<typeof setInterval>;

      function goTo(index: number) {
        slides.forEach((slide, i) => {
          if (i === index) {
            (slide as HTMLElement).style.opacity = '1';
          } else {
            (slide as HTMLElement).style.opacity = '0';
          }
        });
        dots.forEach((dot, i) => {
          if (i === index) {
            dot.classList.add('bg-accent-orange', 'w-4');
            dot.classList.remove('bg-fg-sub/40');
          } else {
            dot.classList.remove('bg-accent-orange', 'w-4');
            dot.classList.add('bg-fg-sub/40');
          }
        });
        current = index;
      }

      function next() {
        if (!paused) {
          goTo((current + 1) % slides.length);
        }
      }

      timer = setInterval(next, interval);

      carousel.addEventListener('mouseenter', () => { paused = true; });
      carousel.addEventListener('mouseleave', () => { paused = false; });

      dots.forEach((dot) => {
        dot.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          const idx = parseInt((dot as HTMLElement).dataset.index || '0');
          goTo(idx);
          
          clearInterval(timer);
          timer = setInterval(next, interval);
        });
      });
    });
  }

  initCarousels();
  document.addEventListener('astro:after-swap', initCarousels);
</script>
